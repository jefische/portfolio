---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import getOrderFromSlug from "src/lib/getOrderFromSlug";
import { Image } from "astro:assets";

// Fetch projects and sort by filename order
const projects = (await getCollection("projects")).sort((a, b) => getOrderFromSlug(a.slug) - getOrderFromSlug(b.slug));

// Create a map for easy lookup by title
const projectMap = new Map(projects.map((p) => [p.data.title, p]));

const getProjectUrl = (title: string) => {
	const project = projectMap.get(title);
	return project ? `/projects/${project.slug}` : "#";
};

// Featured projects for the landing page
const featuredProjects = [
	{
		title: "Secret Santa Exchange",
		img: "/secret_santa_exchange_logo.svg",
		imgBg: "#2d3748",
		imgContain: true,
		desc: "AI-powered web application that organizes gift exchanges and generates personalized gift recommendations.",
		tags: ["Next.js", "Supabase", "OpenAI"],
		url: getProjectUrl("Secret Santa Exchange"),
	},
	{
		title: "Tennis Video Database",
		img: "/tennis-database.png",
		desc: "Full-stack application for browsing and filtering a curated collection of professional tennis match videos.",
		tags: ["React.js", "Spring Boot", "MySQL"],
		url: getProjectUrl("Tennis Video Database"),
	},
	{
		title: "Wildlife Center of Virginia",
		img: "/header-wcv-badge.webp",
		imgContain: true,
		desc: "Civic technology project to digitize hospital animal intake forms with interactive mapping.",
		tags: ["JavaScript", "Leaflet.js", "Bootstrap"],
		url: getProjectUrl("Wildlife Center of Virginia"),
	},
	{
		title: "Central Oregon Irrigation District",
		img: "/COID.PNG",
		imgBg: "#fff",
		imgContain: true,
		desc: "Client water rights application rebuild with BlueChannel, Inc.",
		tags: ["HTML", "CSS", "JavaScript"],
		url: getProjectUrl("Central Oregon Irrigation District"),
	},
	{
		title: "How to Watch Tennis Online",
		img: "/Sports_Tennis-3200x1800.jpg",
		desc: "A blog and guide to watching professional tennis online using a VPN.",
		tags: ["React.js"],
		url: getProjectUrl("Total Tennis TV"),
	},
];

const skills = {
	Frontend: ["React", "Next.js", "Astro", "HTML/CSS", "Tailwind", "Bootstrap"],
	Backend: ["Java", "Spring Boot", "Node.js", "SQL", "Supabase"],
	Tools: ["Git", "VS Code", "Figma", "Netlify", "Vercel"],
	Languages: ["JavaScript", "TypeScript", "Java", "Python", "SQL"],
};
---

<BaseLayout sideBarActiveItemID="home">
	<div class="noise-overlay"></div>

	<!-- ========== HERO ========== -->
	<section class="pt-4 pb-14">
		<div class="animate-fade-up stagger-1">
			<span class="hero-label">
				<span class="status-dot"></span>
				Available for opportunities
			</span>
		</div>

		<h1 class="hero-name mt-4 animate-fade-up stagger-2">Jeremy Fischer</h1>

		<p class="hero-role mt-3 animate-fade-up stagger-3">
			Full-Stack Developer<span class="hero-cursor"></span>
		</p>

		<p class="hero-bio mt-5 animate-fade-up stagger-4">
			Currently a contract software developer with formal training in data analysis. I build clean, user-focused
			web applications and love exploring new technologies. Browse my work below — or check out my <a
				href="/cv"
				class="text-[--accent-glow] hover:underline underline-offset-4">CV</a
			> for the full picture.
		</p>
	</section>

	<!-- ========== SKILLS ========== -->
	<section class="pb-12 animate-fade-up stagger-5">
		<div class="section-header">
			<span class="section-number">01</span>
			<h2>Skills & Tools</h2>
			<div class="section-line"></div>
		</div>

		<div class="skills-grid">
			{
				Object.entries(skills).map(([category, items]) => (
					<div class="skill-category">
						<div class="skill-category-label">{category}</div>
						<div>
							{items.map((skill) => (
								<span class="skill-tag">{skill}</span>
							))}
						</div>
					</div>
				))
			}
		</div>
	</section>

	<!-- ========== PROJECTS ========== -->
	<section class="pb-8 animate-fade-up stagger-6">
		<div class="section-header">
			<span class="section-number">02</span>
			<h2>Featured Projects</h2>
			<div class="section-line"></div>
		</div>

		<div class="flex flex-col gap-4">
			{
				featuredProjects.map((project) => (
					<a href={project.url} class="project-card">
						<div class="project-card-image">
							<Image
								src={project.img}
								width={400}
								height={250}
								format="webp"
								alt={project.title}
								class={project.imgContain ? "object-contain" : "object-cover"}
								style={project.imgBg ? `background-color: ${project.imgBg}; padding: 1rem;` : ""}
							/>
						</div>
						<div class="project-card-body">
							<div class="flex items-center justify-between gap-2">
								<h3 class="project-card-title">{project.title}</h3>
								<span class="project-card-arrow text-lg">→</span>
							</div>
							<p class="project-card-desc">{project.desc}</p>
							<div class="project-card-tags">
								{project.tags.map((tag) => (
									<span class="project-card-tag">{tag}</span>
								))}
							</div>
						</div>
					</a>
				))
			}
		</div>

		<div class="mt-6 text-center">
			<a href="/projects" class="cta-link"> View all projects → </a>
		</div>
	</section>

	<!-- ========== CTA ========== -->
	<section class="animate-fade-up stagger-7">
		<div class="cta-strip">
			<p>Interested in working together?</p>
			<div class="cta-links">
				<a href="https://github.com/jefische" target="_blank" class="cta-link">GitHub</a>
				<a href="https://www.linkedin.com/in/jeremy-ev-fischer" target="_blank" class="cta-link">LinkedIn</a>
				<!-- <a href="/cv" class="cta-link">View CV</a> -->
				<a href="mailto:jeremy.ev.fischer@gmail.com" class="cta-link">jeremy.ev.fischer@gmail.com</a>
			</div>
		</div>
	</section>
</BaseLayout>
